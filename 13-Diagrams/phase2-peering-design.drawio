<mxfile>
  <diagram name="Phase 2 - Peering Design (Hub-and-Spoke)" id="peering-design">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="t1" value="Hybrid Hub-and-Spoke Peering Design&#10;(vnet-soc as Hub)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="50" as="geometry" />
        </mxCell>
        <!-- vnet-identity (Left Spoke) -->
        <mxCell id="identity" value="vnet-identity&#10;10.1.0.0/16&#10;East US 2&#10;(Identity)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- vnet-soc (Center Hub) -->
        <mxCell id="soc" value="vnet-soc (HUB)&#10;10.2.0.0/16&#10;West US 2&#10;(SOC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="430" y="290" width="260" height="120" as="geometry" />
        </mxCell>
        <!-- vnet-attack (Right Spoke) -->
        <mxCell id="attack" value="vnet-attack&#10;10.3.0.0/16&#10;Central US&#10;(Attack)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="820" y="310" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- vnet-automation (Top Spoke) -->
        <mxCell id="automation" value="vnet-automation&#10;10.4.0.0/16&#10;South Central US&#10;(Automation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="220" height="100" as="geometry" />
        </mxCell>
        <!-- Peering Lines -->
        <mxCell id="p1" value="peer-soc-to-identity&#10;peer-identity-to-soc" style="strokeWidth=3;strokeColor=#6c8ebf;fontSize=10;" edge="1" source="soc" target="identity" parent="1" />
        <mxCell id="p2" value="peer-soc-to-attack&#10;peer-attack-to-soc" style="strokeWidth=3;strokeColor=#d6b656;fontSize=10;" edge="1" source="soc" target="attack" parent="1" />
        <mxCell id="p3" value="peer-soc-to-automation&#10;peer-automation-to-soc" style="strokeWidth=3;strokeColor=#82b366;fontSize=10;" edge="1" source="soc" target="automation" parent="1" />
        <!-- Legend -->
        <mxCell id="leg" value="Legend:&#10;Red = Hub (SOC)&#10;Blue = Identity Spoke&#10;Yellow = Attack Spoke&#10;Green = Automation Spoke&#10;Lines = Bidirectional Peering" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="250" height="120" as="geometry" />
        </mxCell>
        <!-- Peering Settings Box -->
        <mxCell id="settings" value="Peering Settings (All):&#10;Allow VNet Access: ✓&#10;Allow Forwarded Traffic: ✓&#10;Gateway Transit: ✗&#10;Remote Gateway: ✗" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="820" y="520" width="250" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
